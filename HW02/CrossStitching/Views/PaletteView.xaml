<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CrossStitching.ViewModels"
             x:Class="CrossStitching.Views.PaletteView"
             x:DataType="vm:PaletteViewModel"
             Title="Palette to choose color">

    <ScrollView Padding="10">
        <GraphicsView x:Name="PaletteGV"
                  WidthRequest="{Binding PaletteWidth}"
                  HeightRequest="{Binding PaletteHeight}"
                  StartInteraction="OnPaletteTapped"
                  HorizontalOptions="Center" />
    </ScrollView>
</ContentPage>