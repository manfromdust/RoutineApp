<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrossStitching.Views.SetupView"
             xmlns:vm="clr-namespace:CrossStitching.ViewModels"
             x:DataType="vm:SetupViewModel"
             Title="SetupView">

    <ScrollView>
        <VerticalStackLayout Padding="14">
            <Label Text="How many rows?" />
            <Entry Text="{Binding InputRows}" Placeholder="Default is 100"
                   Keyboard="Numeric" />
            <Label Text="How many columns?" />
            <Entry Text="{Binding InputCols}" Placeholder="Default is 100"
                   Keyboard="Numeric" />
            <Button Text="Generate canvas" Command="{Binding GenerateCanvasCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>