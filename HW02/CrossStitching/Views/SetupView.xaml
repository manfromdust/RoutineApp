<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrossStitching.Views.SetupView"
             xmlns:vm="clr-namespace:CrossStitching.ViewModels"
             Title="SetupView">
    <ContentPage.BindingContext>
        <vm:SetupViewModel />
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Create" Command="{Binding GenerateCanvasCommand}" />
    </ContentPage.ToolbarItems>
    
    <ScrollView>
        <VerticalStackLayout Padding="14">
            <Label Text="How many rows?" />
            <Entry Text="{Binding Dimensions.Rows}" Placeholder="Default is 100" />
            <Label Text="How many columns?" />
            <Entry Text="{Binding Dimensions.Cols}" Placeholder="Default is 100" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>