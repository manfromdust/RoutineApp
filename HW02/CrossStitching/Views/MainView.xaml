<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CrossStitching.ViewModels"
             x:Class="CrossStitching.Views.MainView"
             Title="Cross Stitching"
             x:Name="MainPage">
    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Create new" Command="{Binding NewCanvasCommand} "/>
        <ToolbarItem Text="Import" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <Grid ColumnDefinitions="Auto, *">
            <CollectionView x:Name="Canvas" Grid.Column="0"
                            ItemsSource="{Binding Pixels}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="{Binding Columns}" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PixelViewModel">
                        <BoxView Color="{Binding Pixel.Color}" HeightRequest="30" WidthRequest="30">
                            <BoxView.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference MainPage},
                                                                        Path=BindingContext.ChangeColorCommand}"
                                                      CommandParameter="{Binding .}" />
                            </BoxView.GestureRecognizers>
                        </BoxView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
            <CollectionView x:Name="Palette"
                            Grid.Column="1"
                            ItemsLayout="VerticalGrid, 4"
                            ItemsSource="{Binding Palette}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <BoxView HeightRequest="10" WidthRequest="10"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ScrollView>
</ContentPage>