<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CrossStitching.ViewModels"
             x:Class="CrossStitching.Views.ImportView"
             Title="Import existing canvas">
    <ContentPage.BindingContext>
        <vm:ImportViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="14" >
            <Label Text="Chosen file:" FontAttributes="Bold" />
            <Label Text="{Binding ChosenFile}" />
            <Button Text="Import" Command="{Binding ImportFromJsonCommand}" />

            <CollectionView ItemsSource="{Binding ImportedFiles}"
                            SelectedItem="{Binding ChosenFile, Mode=TwoWay}"
                            SelectionMode="Single" >
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid Padding="10">
                            <Label Text="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>