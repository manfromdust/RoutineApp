<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CrossStitching.ViewModels"
             x:Class="CrossStitching.Views.ImportView"
             x:DataType="vm:ImportViewModel"
             Title="Import existing canvas">

    <ScrollView>
        <VerticalStackLayout Padding="14" >
            <Label Text="Chosen file:" FontAttributes="Bold" />
            <Label Text="{Binding GetFileName}" />
            <Button Text="Import" Command="{Binding ImportFromJsonCommand}"
                    HorizontalOptions="Start"
                    Margin="0,10,0,10" />
            <Label Text="Existing files:" FontAttributes="Bold" Margin="0,10,0,10" />

                <Border BackgroundColor="Grey" Padding="5"
                    Stroke="Peru" Margin="5,10,0,5" >
                <CollectionView ItemsSource="{Binding ImportedFiles}"
                                SelectedItem="{Binding ChosenFile, Mode=TwoWay}"
                                SelectionMode="Single" >
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid Padding="10">
                                <Label Text="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>