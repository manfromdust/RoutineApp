<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RoutineApp.ViewModels"
             x:Class="RoutineApp.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Main Page">
    <ScrollView>
        <VerticalStackLayout Padding="14" >
            <HorizontalStackLayout>
                <Button HorizontalOptions="Start"
                        Text="Add routine"
                        Command="{Binding AddRoutineCommand}" />
                <Button HorizontalOptions="Center"
                        Text="{Binding ActiveButtonText}"
                        Command="{Binding ChangeActiveCommand}" />
                <Button HorizontalOptions="End"
                        Text="Manage selected routine"
                        Command="{Binding EditRoutineCommand}" />
            </HorizontalStackLayout>
            

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Items}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedItem}" >
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:RoutineItemViewModel">

                        <Grid Padding="10" ColumnDefinitions="Auto, *, Auto">
                            <Label Text="{Binding Item.Name}" FontSize="Medium"
                                   Grid.Column="0" VerticalOptions="Center" />
                        </Grid>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>