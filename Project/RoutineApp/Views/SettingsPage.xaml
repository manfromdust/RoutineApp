<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RoutineApp.ViewModels"
             x:Class="RoutineApp.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="14">
            <Button Text="Clear all data"
                    Command="{Binding ClearDataCommand}"
                    HorizontalOptions="Center"
                    Margin="14" />

            <Border Padding="10"
                    StrokeShape="RoundRectangle 8" >
                <Grid ColumnDefinitions="Auto, *"
                      ColumnSpacing="7" >
                    
                    <Label Text="App theme:"
                           FontSize="Medium"
                           VerticalOptions="Center"
                           Grid.Column="0"/>
                    <Picker ItemsSource="{Binding AppearanceOptions}"
                            SelectedItem="{Binding SelectedAppearance}"
                            Title="Choose a theme"
                            Grid.Column="1" />
                    
                </Grid>

            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>